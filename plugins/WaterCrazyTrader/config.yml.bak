# Переменные equipmentSlot
# HAND - основная рука
# OFF_HAND - левая рука
# HEAD - слот шлема
# CHEST - слот нагрудника
# LEGS - слот штанов
# FEET - слот ботинок
perks:
  spectator:
    distance: 500.0
    noPlayers: "§cВ радиусе 500 блоков нет игроков."
    players: "§eВ радиусе 500 блоков %size% игроков: %entries%"
  health:
    addHealth: 2 # 1 сердечко = 2 ед. здоровья
  expGenerator:
    addExp: 3.0 # сколько опыта добавлять
    equipmentSlot: HAND
  moneyGenerator:
    addMoney: 5.0 # сколько давать денег
    equipmentSlot: HAND
    actionBar: "§6+5$"
  godPickaxe:
    dropAllBlocks: true

messages:
  cantBreak: "§cЭтот блок нельзя сломать этим предметом."
  noMoney: "§cДля покупки этого предмета у тебя не хватает %money%$"
  fullInventory: "§cТвой инвентарь полон"
  transactionError: "§cВо время проведения оплаты произошла ошибка: %error%"
  transactionSuccess: "§aПоздравляем с покупкой предмета"

gui:
  title: "Чокнутый торговец"
  rows: 6
  sallableItems:
    "1":
      slot: 21
      id: "345"
      name: "§9Наблюдатель"
      lore:
      - "§f Кликни на компас в руке,"
      - "§f и он покажет ближайших игроков"
      - "§f в радиусе §e500 §fблоков"
      - "§f"
      - "§fЦена: §a150000$"
      perk: spectator
      price: 150000
    "2":
      slot: 19
      id: "270"
      name: "§9Кирка бога"
      lore:
      - "§f Кирка, способная ломать любой блок"
      - "§f Одноразовое §cиспользование §7(не в чужом привате)"
      - "§f"
      - "§fЦена: §a150000$"
      perk: godpickaxe
      price: 150000
    "3":
      slot: 23
      id: "322"
      name: ""
      lore:
      - "§f После покупки этого яблока вы получите"
      - "§f §c+1 сердце §fк своему ХП §aНАВСЕГДА"
      - "§f §7(До вайпа)"
      - "§f"
      - "§fЦена: §a3000000$"
      perk: health
      price: 3000000
    "4":
      slot: 25
      id: "452"
      name: "§eГенератор опыта"
      lore:
      - "§f Просто возьми в руку §eгенератор"
      - "§f и получай §a+3xp/сек"
      - "§f"
      - "§fЦена: §a300000$"
      perk: expgenerator
      price: 300000
    "5":
      slot: 31
      id: "371"
      name: "§eГенератор денег"
      lore:
      - "§f Просто возьми в руку §eгенератор"
      - "§f и получай §a+5$/сек"
      - "§f"
      - "§fЦена: §a500000$"
      perk: moneygenerator
      price: 500000
  unusedItems: {}
