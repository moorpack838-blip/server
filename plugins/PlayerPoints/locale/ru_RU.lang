# Команды экспорта
command-export-description: '&8 - &d/Рубли export &7- Экспорт данных в storage.yml'
command-export-usage: '&cПрименение: &f/Рубли export'
command-export-success: '&aСохраненные данные были экспортированы в storage.yml.'
